<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet id="2-1" author="system" context="dev,prod">
        <description>Ensure users table has audit columns required by JPA mappings.</description>

        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="users"/>
                <not>
                    <columnExists tableName="users" columnName="updated_at"/>
                </not>
            </and>
        </preConditions>
        <addColumn tableName="users">
            <column name="updated_at" type="TIMESTAMP"/>
        </addColumn>
    </changeSet>

    <changeSet id="2-2" author="system" context="dev,prod">
        <description>Ensure users table has soft-delete column required by login query.</description>

        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="users"/>
                <not>
                    <columnExists tableName="users" columnName="deleted_at"/>
                </not>
            </and>
        </preConditions>
        <addColumn tableName="users">
            <column name="deleted_at" type="TIMESTAMP"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
